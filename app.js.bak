const multer = require('multer'); // 引入搬运工
const path = require('path');     // 引入路径处理工具


// app.js - 后端的核心入口
const express = require('express');
const cors = require('cors');
const db = require('./db'); // 引入刚才写的数据库配置

const app = express();
const PORT = 3003; // 设定端口号

// --- 1. 基础配置 ---
app.use(cors()); // 允许跨域 (让UniApp能访问)
app.use(express.json()); // 允许解析 JSON 数据
app.use('/uploads', express.static('uploads'));

// --- 2. 写接口 (API) ---

// 测试接口：看服务是不是活的
app.get('/', (req, res) => {
    res.send('后端 C 服务正在运行！喵！');
});

// 接口 A: 获取帖子列表 (查)
app.get('/api/posts', async (req, res) => {
    try {
        // 去数据库查询所有帖子，按时间倒序排
        const [rows] = await db.query('SELECT * FROM posts ORDER BY id DESC');
        res.json({
            code: 200,
            msg: '获取成功',
            data: rows
        });
    } catch (error) {
        console.error('查询失败:', error);
        res.status(500).json({ msg: '数据库查询出错，请检查数据库是否已创建' });
    }
});

// 接口 B: 发布帖子 (增) - [已升级] 支持图片
app.post('/api/posts', async (req, res) => {
    try {
        // 1. 从前端拿数据 (现在多拿一个 images)
        // images 应该是一个数组，比如 ["url1", "url2"]，我们需要把它转成字符串存进去
        const { content, userId, type, images } = req.body; 
        
        // 2. 简单的检查
        if (!content) return res.status(400).json({ msg: '内容不能为空' });

        // 3. 处理图片格式 (把数组转成 JSON 字符串存入数据库)
        const imagesStr = images ? JSON.stringify(images) : '[]';

        // 4. 插入数据库 (多存一列 images)
        const sql = 'INSERT INTO posts (content, user_id, type, images) VALUES (?, ?, ?, ?)';
        const [result] = await db.execute(sql, [content, userId || 0, type || 'daily', imagesStr]);

        res.json({
            code: 200,
            msg: '发布成功',
            data: { id: result.insertId }
        });
    } catch (error) {
        console.error('发布失败:', error);
        res.status(500).json({ msg: '发布失败，请检查数据库' });
    }
});

// --- 接口 C: 提交物资捐献 (前端填表单用) ---
app.post('/api/donations', async (req, res) => {
    try {
        // 1. 拿数据
        const { itemName, quantity, userId } = req.body;
        
        // 2. 简单的检查
        if (!itemName || !quantity) {
            return res.status(400).json({ msg: '请填写物资名称和数量' });
        }

        // 3. 存入数据库
        const sql = 'INSERT INTO donations (item_name, quantity, user_id) VALUES (?, ?, ?)';
        await db.execute(sql, [itemName, quantity, userId || 0]);

        res.json({ code: 200, msg: '捐献提交成功，感谢您的爱心！' });
    } catch (error) {
        console.error(error);
        res.status(500).json({ msg: '提交失败' });
    }
});

// --- 接口 D: 查看我的捐献记录 (前端“我的记录”用) ---
app.get('/api/donations', async (req, res) => {
    try {
        const [rows] = await db.query('SELECT * FROM donations ORDER BY id DESC');
        res.json({ code: 200, data: rows });
    } catch (error) {
        res.status(500).json({ msg: '获取失败' });
    }
});

// --- 接口 E: 给帖子点赞 (改) ---
// 用法: POST http://localhost:3003/api/posts/like
app.post('/api/posts/like', async (req, res) => {
    try {
        const { postId } = req.body; // 前端传过来要点赞的帖子ID
        
        // 让数据库里的 likes 字段 +1
        const sql = 'UPDATE posts SET likes = likes + 1 WHERE id = ?';
        await db.execute(sql, [postId]);

        res.json({ code: 200, msg: '点赞成功！' });
    } catch (error) {
        console.error(error);
        res.status(500).json({ msg: '点赞失败' });
    }
});

// --- 接口 F: 删除帖子 (删) ---
// 用法: POST http://localhost:3003/api/posts/delete
app.post('/api/posts/delete', async (req, res) => {
    try {
        const { postId } = req.body;

        // 从数据库里删掉这一行
        const sql = 'DELETE FROM posts WHERE id = ?';
        await db.execute(sql, [postId]);

        res.json({ code: 200, msg: '删除成功' });
    } catch (error) {
        console.error(error);
        res.status(500).json({ msg: '删除失败' });
    }
});

// --- 核心配置：告诉 Multer 把文件存哪里、叫什么名 ---
const storage = multer.diskStorage({
    destination: function (req, file, cb) {
        cb(null, 'uploads/'); // 存到 uploads 文件夹
    },
    filename: function (req, file, cb) {
        // 给文件起个独一无二的名字：时间戳 + 随机数 + 后缀名 (防止文件名冲突)
        const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1E9);
        cb(null, uniqueSuffix + path.extname(file.originalname));
    }
});
const upload = multer({ storage: storage });

// --- 接口 G: 上传图片 (单张) ---
// 用法: POST http://localhost:3003/api/upload
// 注意：这里用了 upload.single('file')，前端传的时候 key 必须是 'file'
app.post('/api/upload', upload.single('file'), (req, res) => {
    try {
        const file = req.file;
        if (!file) {
            return res.status(400).json({ msg: '请选择要上传的图片' });
        }
        // 返回图片的访问地址
        const fileUrl = `http://localhost:3003/uploads/${file.filename}`;
        res.json({ 
            code: 200, 
            msg: '上传成功', 
            url: fileUrl  // 前端拿到这个 URL 后，再把它塞到“发布帖子”的接口里
        });
    } catch (error) {
        console.error(error);
        res.status(500).json({ msg: '上传失败' });
    }
});

// --- 3. 启动服务 ---
app.listen(PORT, () => {
    console.log(`---------------------------------------`);
    console.log(` 🚀 后端 C 服务已启动! `);
    console.log(` 📡 地址: http://localhost:${PORT}`);
    console.log(`---------------------------------------`);
});