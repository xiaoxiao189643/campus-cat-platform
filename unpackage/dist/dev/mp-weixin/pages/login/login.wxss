
.login-container.data-v-e4e4508d {
  padding: 60rpx 60rpx;
  min-height: 100vh;
  background: #FFFFFF;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.logo-section.data-v-e4e4508d {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.logo.data-v-e4e4508d {
  width: 180rpx;
  height: 180rpx;
  border-radius: 36rpx;
  margin-bottom: 40rpx;
  background: #F5F5F5;
}
.app-name.data-v-e4e4508d {
  font-size: 40rpx;
  color: #333333;
  font-weight: 600;
}
.login-form.data-v-e4e4508d {
  width: 100%;
  max-width: 600rpx;
  background: transparent;
  padding: 0;
}
.form-section.data-v-e4e4508d {
  margin-bottom: 40rpx;
}
.input-group.data-v-e4e4508d {
  margin-bottom: 32rpx;
}
.input-wrapper.data-v-e4e4508d {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0 32rpx;
  height: 96rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #E5E5E5;
}
.input-icon.data-v-e4e4508d {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.input-field.data-v-e4e4508d {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  height: 100%;
}
.password-toggle.data-v-e4e4508d {
  font-size: 40rpx;
  margin-left: 24rpx;
  flex-shrink: 0;
  cursor: pointer;
}
.login-btn.data-v-e4e4508d {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}
.username-btn.data-v-e4e4508d {
  background: #ffcaca;
  color: #ffffff;
}
.username-btn.data-v-e4e4508d:disabled {
  background: #FF9999;
  color: #ffcaca;
  opacity: 0.6;
  box-shadow: none;
}
.wechat-btn.data-v-e4e4508d {
  background: #FF9999;
  margin-top: 0;
}
.wechat-btn.data-v-e4e4508d:disabled {
  background: #ffcaca;
  box-shadow: none;
}
.btn-content.data-v-e4e4508d {
  display: flex;
  align-items: center;
  justify-content: center;
}
.wechat-icon.data-v-e4e4508d {
  font-size: 40rpx;
  margin-right: 16rpx;
}
.btn-text.data-v-e4e4508d {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
}
.divider.data-v-e4e4508d {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}
.divider-line.data-v-e4e4508d {
  flex: 1;
  height: 1rpx;
  background: #cecece;
}
.divider-text.data-v-e4e4508d {
  margin: 0 24rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 新增注册链接样式 */
.register-link.data-v-e4e4508d {
  margin-top: 40rpx;
  text-align: center;
}
.register-text.data-v-e4e4508d {
  font-size: 28rpx;
  color: #999999;
  text-decoration: underline;
}
.agreement.data-v-e4e4508d {
  margin-top: 60rpx;
  text-align: center;
}
.agreement-text.data-v-e4e4508d {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}
.loading-mask.data-v-e4e4508d {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.loading-content.data-v-e4e4508d {
  background: #FFFFFF;
  padding: 60rpx 80rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}
.loading-text.data-v-e4e4508d {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #333333;
}
